# ─────────────────────────────────────────────────────────────────────────────
# Modèle de variables d'environnement du BACK-END (NestJS)
# Copie ce fichier en .env pour le développement local.
# En production (Render), saisis ces clés dans l'onglet "Environment".
# ⚠️ Ne JAMAIS commiter le vrai .env (il est gitignoré).
# ─────────────────────────────────────────────────────────────────────────────

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_moi_par_une_longue_chaine_aleatoire
# BNF-02 : 30 min d'inactivité (prolongé automatiquement tant que l'utilisateur est actif)
JWT_EXPIRES_IN=30m

# ─── Base de données PostgreSQL ──────────────────────────────────────────────
# En LOCAL : ta base locale.
# En PROD  : copie les infos de connexion Aiven (onglet "Overview" du service).
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=motdepasse
DB_NAME=ecole_primaire
# ⚠️ Aiven (et la plupart des Postgres managés) EXIGENT le SSL : mettre true en prod.
DB_SSL=false

# ─── Email (Brevo SMTP) ──────────────────────────────────────────────────────
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USER=xxxxxxxxx@smtp-brevo.com
MAIL_PASS=xxxxxxxxxxxxx
MAIL_FROM="BrightSchool <brightschool.noreply@gmail.com>"
# En production, laisser à false pour vérifier le certificat SMTP.
MAIL_TLS_INSECURE=false
